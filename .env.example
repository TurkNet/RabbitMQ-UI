# ──────────────────────────────────────────────────────────────────────────────
# RabbitMQ Dashboard — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────

# ─── Admin Ayarları ──────────────────────────────────────────────────────────
# Admin modunu aktif et (true/false)
# false ise login ekranı gelmez ve cluster ekleme/çıkarma yapılabilsin.
ENABLE_ADMIN=false

# UI'da "Admin Login" butonuyla giriş yapılacak şifre (ENABLE_ADMIN=true ise zorunlu)
ADMIN_PASSWORD=change_me_strong_password

# JWT token imzalama anahtarı (ENABLE_ADMIN=true ise zorunlu)
JWT_SECRET=change_me_jwt_secret_very_long_random_string

# ─── Güvenlik ─────────────────────────────────────────────────────────────────
# Cluster şifrelerini şifrelemek için kullanılan anahtar (ör. openssl rand -hex 16)
ENCRYPTION_KEY=change_me_encryption_key_32chars


# ─── Yüklenecek Cluster'lar ───────────────────────────────────────────────────
# Container başlarken bu cluster'lar otomatik yüklenir.
#
# Format: JSON
# Örnek :

# CLUSTER_1={"name":"Production Cluster","url":"http://rabbit_ip:15672","username":"admin","password":"strong_password_1"}
# CLUSTER_2={"name":"Test Cluster","url":"http://rabbit_ip:15672","username":"admin","password":"strong_password_2"}

